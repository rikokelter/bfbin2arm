  pmid = {32299845},
  keywords = {disease activity,systemic sclerosis,treatment},
  file = {/Users/riko/Zotero/storage/RCI3UR8U/Khanna et al. - 2020 - Riociguat in patients with early diffuse cutaneous systemic sclerosis (RISE-SSc) randomised, double.pdf}
}

