@article{wenRandomizedDoubleBlindPlaceboControlled2019,
  title = {A {{Randomized Double-Blind Placebo-Controlled Phase II Trial}} of {{Dendritic Cell Vaccine ICT-107}} in {{Newly Diagnosed Patients}} with {{Glioblastoma}}},
  author = {Wen, Patrick Y. and Reardon, David A. and Armstrong, Terri S. and Phuphanich, Surasak and Aiken, Robert D. and Landolfi, Joseph C. and Curry, William T. and Zhu, Jay-Jiguang and Glantz, Michael and Peereboom, David M. and Markert, James M. and LaRocca, Renato and O'Rourke, Donald M. and Fink, Karen and Kim, Lyndon and Gruber, Michael and Lesser, Glenn J. and Pan, Edward and Kesari, Santosh and Muzikansky, Alona and Pinilla, Clemencia and Santos, Radleigh G. and Yu, John S.},
  year = 2019,
